# Comma-separated list of clock hostnames or IPs
CLOCK_HOSTS=ntp1,ntp2

# SNMP v2c community string
SNMP_COMMUNITY=public

# Prometheus Pushgateway URL (no trailing slash)
PUSHGATEWAY_URL=http://ec2-96-0-75-101.ap-southeast-2.compute.amazonaws.com:9091

# Poll interval in milliseconds (default: 60000)
POLL_INTERVAL=60000
